# ASG‑x environment variables
# Copy this file to .env and fill in values for local development.
# Do not commit .env to version control.

# Submission mode: "mock" | "firebase"
# "mock" is the default — all submissions stay in sessionStorage.
# "firebase" requires valid Firebase config and emulator setup.
VITE_ASGX_SUBMISSION_MODE=mock
VITE_ASGX_ENABLE_DEBUG=false
VITE_ASGX_DEMO_MODE=true

# Firebase configuration (only needed for VITE_ASGX_SUBMISSION_MODE=firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "true" only in local Firebase emulator testing
VITE_USE_FIREBASE_EMULATOR=false
