# ASG‑x Firebase emulator local override
# Copy to .env.local when testing against Firestore emulator.
# Do not commit .env.local to version control.

VITE_ASGX_SUBMISSION_MODE=firebase
VITE_ASGX_ENABLE_DEBUG=true
VITE_ASGX_DEMO_MODE=true
VITE_USE_FIREBASE_EMULATOR=true

VITE_FIREBASE_API_KEY=demo-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-asgx-local.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-asgx-local
VITE_FIREBASE_STORAGE_BUCKET=demo-asgx-local.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=demo-app-id
