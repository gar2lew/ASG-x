rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // === EMULATOR-ONLY DEVELOPMENT RULES ===
    // These rules are for local Firestore emulator testing only.
    // They are NOT production-safe. DO NOT DEPLOY TO PRODUCTION.
    //
    // Production rules must:
    //   1. Deny all direct client writes
    //   2. Allow writes only from Firebase Functions (server-side)
    //   3. Be reviewed by security and compliance before deployment
    //   4. Include field-level validation for required fields
    //
    // See docs/asg-x-production-readiness-review.md for full rollout plan.

    match /asgXLeadSubmissions/{docId} {
      // Allow full access during emulator development
      allow read, write: if true;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
